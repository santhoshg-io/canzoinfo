# Direct SMTP Email Transport Credentials
# Copy this file to .env and fill in your actual SMTP credentials

# SMTP Server Connection Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# SMTP Authentication Credentials
# For Gmail: Use your Gmail email and an 16-character App Password (Google Account > Security > App Passwords)
# For Custom Domain / cPanel: Use your full email address and account password
SMTP_USER=tamiltamilboss090@gmail.com
SMTP_PASS=your_app_password_here

# Destination Email Inbox (Where form submissions will be delivered)
TO_EMAIL=tamiltamilboss090@gmail.com
